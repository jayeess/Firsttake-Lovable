NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_SHOW_TEST_CASES=false

# Server-only Firebase Admin SDK credentials. Never prefix these with NEXT_PUBLIC.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional Playwright accounts. Leave unset to run public and unauthenticated
# route-gating smoke tests only.
E2E_TALENT_EMAIL=
E2E_TALENT_PASSWORD=
E2E_RECRUITER_EMAIL=
E2E_RECRUITER_PASSWORD=
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
