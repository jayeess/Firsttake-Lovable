rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUser(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function currentUserType() {
      return userDoc(request.auth.uid).data.userType;
    }

    function accountActive() {
      return userDoc(request.auth.uid).data.accountStatus != 'SUSPENDED';
    }

    function isTalent() {
      return signedIn() && currentUserType() == 'TALENT' && accountActive();
    }

    function isRecruiter() {
      return signedIn() && currentUserType() == 'RECRUITER' && accountActive();
    }

    function recruiterApproved(uid) {
      return get(/databases/$(database)/documents/recruiterVerifications/$(uid)).data.status
        == 'approved';
    }

    function validAuditionStatus(status) {
      return status in [
        'ACTIVE',
        'CLOSED',
        'CANCELLED',
        'DRAFT'
      ];
    }

    function validTalentPoolStatus(status) {
      return status in [
        'SAVED',
        'WATCHLIST',
        'FUTURE_FIT',
        'DO_NOT_CONTACT'
      ];
    }

    function validTalentPoolEntry(data) {
      return data.id is string
        && data.id == data.recruiterId + '__' + data.talentId
        && data.recruiterId is string
        && data.talentId is string
        && data.talentId.size() > 0
        && data.talentId.size() <= 128
        && data.talentNameSnapshot is string
        && data.talentNameSnapshot.size() > 0
        && data.talentNameSnapshot.size() <= 120
        && data.get('talentPublicSlug', '') is string
        && data.get('talentPublicSlug', '').size() <= 120
        && data.get('talentCategorySnapshot', '') is string
        && data.get('talentCategorySnapshot', '').size() <= 60
        && data.get('sourceApplicationId', '') is string
        && data.get('sourceApplicationId', '').size() <= 128
        && data.get('sourceAuditionId', '') is string
        && data.get('sourceAuditionId', '').size() <= 128
        && data.get('sourceAuditionTitleSnapshot', '') is string
        && data.get('sourceAuditionTitleSnapshot', '').size() <= 160
        && validTalentPoolStatus(data.status)
        && data.tags is list
        && data.tags.size() <= 20
        && data.privateNote is string
        && data.privateNote.size() <= 1000
        && data.keys().hasOnly([
          'id',
          'recruiterId',
          'talentId',
          'talentNameSnapshot',
          'talentPublicSlug',
          'talentCategorySnapshot',
          'sourceApplicationId',
          'sourceAuditionId',
          'sourceAuditionTitleSnapshot',
          'status',
          'tags',
          'privateNote',
          'createdAt',
          'updatedAt'
        ]);
    }

    function ownsTalentPoolEntryId(entryId) {
      return signedIn() && entryId.matches(request.auth.uid + '__.*');
    }

    match /users/{uid} {
      allow create: if ownsUser(uid)
        && request.resource.data.userType in ['TALENT', 'RECRUITER'];
      allow read: if ownsUser(uid) || isAdmin();
      allow update: if ownsUser(uid)
        && request.resource.data.userType == resource.data.userType
        && request.resource.data.accountStatus == resource.data.accountStatus
        && request.resource.data.get('verificationStatus', 'not_submitted')
          == resource.data.get('verificationStatus', 'not_submitted')
        && request.resource.data.get('isAdmin', false)
          == resource.data.get('isAdmin', false);
      allow delete: if ownsUser(uid);

      match /talentProfiles/{profileId} {
        allow read: if signedIn();
        allow create: if ownsUser(uid)
          && profileId == uid
          && accountActive()
          && request.resource.data.get(
            'talentVerificationStatus',
            'not_submitted'
          ) == 'not_submitted'
          && request.resource.data.get('verifiedAt', null) == null
          && request.resource.data.get('publicProfileEnabled', false) == false
          && request.resource.data.get('publicSlug', '') == '';
        allow update: if ownsUser(uid)
          && profileId == uid
          && accountActive()
          && request.resource.data.get(
            'talentVerificationStatus',
            'not_submitted'
          ) == resource.data.get(
            'talentVerificationStatus',
            'not_submitted'
          )
          && request.resource.data.get('verifiedAt', null)
            == resource.data.get('verifiedAt', null)
          && request.resource.data.get('publicProfileEnabled', false)
            == resource.data.get('publicProfileEnabled', false)
          && request.resource.data.get('publicSlug', '')
            == resource.data.get('publicSlug', '')
          && request.resource.data.get('publicProfileCreatedAt', null)
            == resource.data.get('publicProfileCreatedAt', null)
          && request.resource.data.get('publicProfileUpdatedAt', null)
            == resource.data.get('publicProfileUpdatedAt', null);

        match /media/{mediaId} {
          allow read: if ownsUser(uid)
            || isAdmin()
            || (resource.data.visibility == 'public'
              && resource.data.moderationStatus == 'active')
            || (isRecruiter()
              && recruiterApproved(request.auth.uid)
              && resource.data.visibility in ['recruiters', 'public']
              && resource.data.moderationStatus == 'active');
          allow create: if ownsUser(uid)
            && profileId == uid
            && isTalent()
            && request.resource.data.ownerId == request.auth.uid
            && request.resource.data.moderationStatus == 'active'
            && request.resource.data.type in [
              'image',
              'video_link',
              'showreel_link',
              'document'
            ]
            && request.resource.data.visibility in [
              'private',
              'recruiters',
              'public'
            ]
            && request.resource.data.keys().hasOnly([
              'ownerId',
              'type',
              'title',
              'description',
              'url',
              'storagePath',
              'thumbnailUrl',
              'externalUrl',
              'mimeType',
              'sizeBytes',
              'sortOrder',
              'isFeatured',
              'visibility',
              'moderationStatus',
              'createdAt',
              'updatedAt'
            ]);
          allow update: if (isAdmin()
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'moderationStatus',
                'moderationReason',
                'moderatedBy',
                'moderatedAt',
                'updatedAt'
              ]))
            || (ownsUser(uid)
              && profileId == uid
              && isTalent()
              && request.resource.data.ownerId == resource.data.ownerId
              && request.resource.data.moderationStatus
                == resource.data.moderationStatus
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'title',
                'description',
                'visibility',
                'sortOrder',
                'isFeatured',
                'updatedAt'
              ]));
          allow delete: if ownsUser(uid)
            && profileId == uid
            && isTalent();
        }
      }

      match /recruiterProfiles/{profileId} {
        allow read: if signedIn();
        allow create: if ownsUser(uid)
          && request.resource.data.isVerified == false;
        allow update: if ownsUser(uid)
          && request.resource.data.isVerified == resource.data.isVerified
          && request.resource.data.get('verificationStatus', 'not_submitted')
            == resource.data.get('verificationStatus', 'not_submitted');
      }

      match /savedAuditions/{auditionId} {
        allow read: if ownsUser(uid) && isTalent();
        allow create, update: if ownsUser(uid)
          && isTalent()
          && request.resource.data.auditionId == auditionId
          && get(/databases/$(database)/documents/auditions/$(auditionId)).data.status
            == 'ACTIVE'
          && get(/databases/$(database)/documents/auditions/$(auditionId)).data
            .get('moderationStatus', 'VISIBLE') == 'VISIBLE';
        allow delete: if ownsUser(uid) && isTalent();
      }

    }

    match /notifications/{notificationId} {
      allow read: if signedIn()
        && resource.data.recipientId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.recipientId == request.auth.uid
        && request.resource.data.recipientId == resource.data.recipientId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'read',
          'readAt'
        ])
        && request.resource.data.read == true;
      allow create, delete: if false;
    }

    match /recruiterTalentPool/{entryId} {
      allow get: if isRecruiter()
        && (ownsTalentPoolEntryId(entryId)
          || resource.data.recruiterId == request.auth.uid);
      allow list: if isRecruiter()
        && resource.data.recruiterId == request.auth.uid;
      allow create: if isRecruiter()
        && request.resource.data.recruiterId == request.auth.uid
        && entryId == request.resource.data.id
        && validTalentPoolEntry(request.resource.data);
      allow update: if isRecruiter()
        && resource.data.recruiterId == request.auth.uid
        && request.resource.data.recruiterId == resource.data.recruiterId
        && request.resource.data.talentId == resource.data.talentId
        && request.resource.data.id == resource.data.id
        && entryId == request.resource.data.id
        && validTalentPoolEntry(request.resource.data);
      allow delete: if isRecruiter()
        && resource.data.recruiterId == request.auth.uid;
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.reporterRole == currentUserType()
        && request.resource.data.targetType in [
          'audition',
          'talentProfile',
          'publicProfile',
          'media',
          'message',
          'conversation',
          'recruiter',
          'talent'
        ]
        && request.resource.data.reasonCode in [
          'fake_audition',
          'scam_or_fraud',
          'inappropriate_content',
          'harassment',
          'spam',
          'impersonation',
          'unsafe_contact_request',
          'misleading_information',
          'other'
        ]
        && request.resource.data.reasonText is string
        && request.resource.data.reasonText.size() <= 1000
        && request.resource.data.status == 'open'
        && request.resource.data.priority in ['low', 'medium', 'high', 'urgent']
        && request.resource.data.evidenceSnapshots == {}
        && request.resource.data.reviewedBy == null
        && request.resource.data.reviewedAt == null
        && request.resource.data.resolutionAction == null
        && request.resource.data.resolutionNote == null
        && request.resource.data.adminOnlyNotes == null
        && request.resource.data.keys().hasOnly([
          'targetType',
          'targetId',
          'targetKey',
          'targetOwnerId',
          'reporterId',
          'reporterRole',
          'reasonCode',
          'reasonText',
          'status',
          'priority',
          'evidenceSnapshots',
          'createdAt',
          'updatedAt',
          'reviewedBy',
          'reviewedAt',
          'resolutionAction',
          'resolutionNote',
          'adminOnlyNotes'
        ]);
      allow update: if isAdmin();
      allow delete: if false;

      match /events/{eventId} {
        allow read, write: if isAdmin();
      }
    }

    match /conversations/{conversationId} {
      allow read: if signedIn()
        && (request.auth.uid in resource.data.participantIds || isAdmin());
      allow create, delete: if false;
      allow update: if (signedIn()
          && request.auth.uid in resource.data.participantIds
          && request.resource.data.participantIds == resource.data.participantIds
          && request.resource.data.recruiterId == resource.data.recruiterId
          && request.resource.data.talentId == resource.data.talentId
          && request.resource.data.applicationId == resource.data.applicationId
          && request.resource.data.auditionId == resource.data.auditionId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'unreadBy',
            'updatedAt'
          ])
          && request.resource.data.unreadBy
            == resource.data.unreadBy.removeAll([request.auth.uid]))
        || (isAdmin()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'updatedAt',
            'moderationReason',
            'moderatedBy',
            'moderatedAt'
          ]));

      match /messages/{messageId} {
        allow read: if signedIn()
          && (request.auth.uid in get(
            /databases/$(database)/documents/conversations/$(conversationId)
          ).data.participantIds || isAdmin());
        allow create: if signedIn()
          && request.auth.uid in get(
            /databases/$(database)/documents/conversations/$(conversationId)
          ).data.participantIds
          && get(
            /databases/$(database)/documents/conversations/$(conversationId)
          ).data.status == 'active'
          && request.resource.data.conversationId == conversationId
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.senderRole
            == get(
              /databases/$(database)/documents/conversations/$(conversationId)
            ).data.participantRoles[request.auth.uid]
          && request.resource.data.moderationStatus == 'active'
          && request.resource.data.system == false
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0
          && request.resource.data.body.size() <= 1000
          && request.resource.data.readBy.hasOnly([
            request.auth.uid
          ])
          && request.resource.data.keys().hasOnly([
            'conversationId',
            'senderId',
            'senderRole',
            'body',
            'createdAt',
            'editedAt',
            'deletedAt',
            'moderationStatus',
            'readBy',
            'system',
            'metadata'
          ]);
        allow update: if (signedIn()
            && request.auth.uid in get(
              /databases/$(database)/documents/conversations/$(conversationId)
            ).data.participantIds
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'readBy'
            ])
            && request.resource.data.readBy.hasAll(resource.data.readBy)
            && request.resource.data.readBy.hasOnly(
              get(
                /databases/$(database)/documents/conversations/$(conversationId)
              ).data.participantIds
            ))
          || (isAdmin()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'moderationStatus',
              'moderationReason',
              'moderatedBy',
              'moderatedAt'
            ]));
        allow delete: if false;
      }
    }

    match /publicTalentProfiles/{slug} {
      allow read: if resource.data.enabled == true;
      allow create, update, delete: if false;
    }

    match /recruiterVerifications/{uid} {
      allow read: if ownsUser(uid) || isAdmin();
      allow create: if ownsUser(uid)
        && currentUserType() == 'RECRUITER'
        && request.resource.data.recruiterId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasOnly([
          'recruiterId',
          'recruiterEmail',
          'legalName',
          'contactPerson',
          'phone',
          'website',
          'socialProofUrl',
          'businessType',
          'workDescription',
          'verificationNotes',
          'status',
          'submittedAt',
          'updatedAt'
        ]);
      allow update: if ownsUser(uid)
        && currentUserType() == 'RECRUITER'
        && resource.data.status in ['not_submitted', 'rejected']
        && request.resource.data.status == 'pending'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'legalName',
          'contactPerson',
          'phone',
          'website',
          'socialProofUrl',
          'businessType',
          'workDescription',
          'verificationNotes',
          'status',
          'submittedAt',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /talentVerifications/{uid} {
      allow read: if ownsUser(uid) || isAdmin();
      allow create: if ownsUser(uid)
        && currentUserType() == 'TALENT'
        && request.resource.data.talentId == request.auth.uid
        && request.resource.data.talentVerificationStatus == 'pending'
        && request.resource.data.profileCompletenessScore >= 0
        && request.resource.data.profileCompletenessScore <= 100
        && request.resource.data.keys().hasOnly([
          'talentId',
          'talentEmail',
          'talentVerificationStatus',
          'profileCompletenessScore',
          'profileCompletenessChecklist',
          'submittedAt',
          'updatedAt'
        ]);
      allow update: if ownsUser(uid)
        && currentUserType() == 'TALENT'
        && resource.data.talentVerificationStatus in [
          'not_submitted',
          'rejected'
        ]
        && request.resource.data.talentVerificationStatus == 'pending'
        && request.resource.data.profileCompletenessScore >= 0
        && request.resource.data.profileCompletenessScore <= 100
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'talentVerificationStatus',
          'profileCompletenessScore',
          'profileCompletenessChecklist',
          'submittedAt',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /auditions/{auditionId} {
      allow read: if signedIn()
        && ((isTalent()
            && resource.data.status == 'ACTIVE'
            && resource.data.get('moderationStatus', 'VISIBLE') == 'VISIBLE')
          || (isRecruiter()
            && ((resource.data.status == 'ACTIVE'
                && resource.data.get('moderationStatus', 'VISIBLE') == 'VISIBLE')
              || resource.data.recruiterId == request.auth.uid))
          || isAdmin());
      allow create: if isRecruiter()
        && recruiterApproved(request.auth.uid)
        && request.resource.data.recruiterId == request.auth.uid
        && validAuditionStatus(request.resource.data.status)
        && request.resource.data.get('applicantCount', 0) == 0
        && request.resource.data.moderationStatus == 'VISIBLE'
        && request.resource.data.get('screeningQuestions', []).size() <= 8;
      allow update: if isRecruiter()
        && recruiterApproved(request.auth.uid)
        && resource.data.get('moderationStatus', 'VISIBLE') != 'REMOVED'
        && resource.data.recruiterId == request.auth.uid
        && request.resource.data.recruiterId == resource.data.recruiterId
        && validAuditionStatus(request.resource.data.status)
        && request.resource.data.get('applicantCount', 0)
          == resource.data.get('applicantCount', 0)
        && request.resource.data.get('moderationStatus', 'VISIBLE')
          == resource.data.get('moderationStatus', 'VISIBLE')
        && request.resource.data.get('moderationReason', '')
          == resource.data.get('moderationReason', '')
        && request.resource.data.get('screeningQuestions', []).size() <= 8;
      allow delete: if false;

      match /applications/{talentId} {
        allow create: if isTalent()
          && talentId == request.auth.uid
          && request.resource.data.talentId == request.auth.uid
          && request.resource.data.status == 'APPLIED'
          && get(/databases/$(database)/documents/auditions/$(auditionId)).data
            .get('moderationStatus', 'VISIBLE') != 'REMOVED'
          && get(/databases/$(database)/documents/auditions/$(auditionId)).data
            .status == 'ACTIVE'
          && get(/databases/$(database)/documents/auditions/$(auditionId)).data
            .deadline > request.time;
        allow read: if signedIn()
          && (talentId == request.auth.uid
            || get(/databases/$(database)/documents/auditions/$(auditionId)).data.recruiterId == request.auth.uid
            || isAdmin());
        allow update: if isRecruiter()
          && get(/databases/$(database)/documents/auditions/$(auditionId)).data.recruiterId == request.auth.uid
          && resource.data.get('status', 'APPLIED') != 'WITHDRAWN'
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              'status',
              'recruiterStatus',
              'reviewedAt',
              'shortlistedAt',
              'rejectedAt',
              'selectedAt',
              'statusUpdatedAt',
              'statusUpdatedBy',
              'recruiterNote',
              'recruiterRating',
              'internalTags',
              'lastRecruiterActionAt',
              'statusHistory',
              'lastStatusChange',
              'updatedAt',
              'recruiterNotes',
              'talentNextStepNote',
              'rejectionReason'
            ])
          && (request.resource.data.status == resource.data.status
            || request.resource.data.status in [
              'VIEWED',
              'UNDER_REVIEW',
              'SHORTLISTED',
              'CALLBACK',
              'FINAL_ROUND',
              'MAYBE',
              'REJECTED',
              'SELECTED'
            ])
          && request.resource.data.get('recruiterStatus', request.resource.data.status)
            == request.resource.data.status
          && request.resource.data.get('statusUpdatedBy', request.auth.uid)
            == request.auth.uid
          && request.resource.data.get('recruiterRating', 1) >= 1
          && request.resource.data.get('recruiterRating', 5) <= 5
          && request.resource.data.get('internalTags', []).size() <= 10
          && request.resource.data.get('talentNextStepNote', '').size() <= 400;
        allow delete: if false;
      }
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /{path=**}/applications/{applicationId} {
      allow read: if isAdmin()
        || (isTalent() && resource.data.talentId == request.auth.uid);
    }
  }
}
