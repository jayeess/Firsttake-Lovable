rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUser(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function currentUserType() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userType;
    }

    function isTalent() {
      return signedIn() && currentUserType() == 'TALENT';
    }

    function isRecruiter() {
      return signedIn() && currentUserType() == 'RECRUITER';
    }

    match /users/{uid} {
      allow create: if ownsUser(uid)
        && request.resource.data.userType in ['TALENT', 'RECRUITER'];
      allow read: if ownsUser(uid);
      allow update: if ownsUser(uid)
        && request.resource.data.userType == resource.data.userType
        && request.resource.data.get('isAdmin', false)
          == resource.data.get('isAdmin', false);
      allow delete: if ownsUser(uid);

      match /talentProfiles/{profileId} {
        allow read: if signedIn();
        allow write: if ownsUser(uid);
      }

      match /recruiterProfiles/{profileId} {
        allow read: if signedIn();
        allow create: if ownsUser(uid)
          && request.resource.data.isVerified == false;
        allow update: if ownsUser(uid)
          && request.resource.data.isVerified == resource.data.isVerified;
      }

      match /notifications/{notificationId} {
        allow read, update: if ownsUser(uid);
        allow create: if signedIn();
      }
    }

    match /auditions/{auditionId} {
      allow read: if signedIn();
      allow create: if isRecruiter()
        && request.resource.data.recruiterId == request.auth.uid;
      allow update: if (
          isRecruiter() && resource.data.recruiterId == request.auth.uid
        ) || (
          isTalent()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['applicantCount', 'updatedAt'])
          && (
            (
              request.resource.data.applicantCount == resource.data.applicantCount + 1
              && !exists(/databases/$(database)/documents/auditions/$(auditionId)/applications/$(request.auth.uid))
              && existsAfter(/databases/$(database)/documents/auditions/$(auditionId)/applications/$(request.auth.uid))
            ) || (
              request.resource.data.applicantCount == resource.data.applicantCount - 1
              && exists(/databases/$(database)/documents/auditions/$(auditionId)/applications/$(request.auth.uid))
              && !existsAfter(/databases/$(database)/documents/auditions/$(auditionId)/applications/$(request.auth.uid))
            )
          )
        );
      allow delete: if isRecruiter()
        && resource.data.recruiterId == request.auth.uid;

      match /applications/{talentId} {
        allow create: if isTalent()
          && talentId == request.auth.uid
          && request.resource.data.talentId == request.auth.uid
          && request.resource.data.status == 'APPLIED'
          && getAfter(/databases/$(database)/documents/auditions/$(auditionId)).data.applicantCount
            == get(/databases/$(database)/documents/auditions/$(auditionId)).data.applicantCount + 1;
        allow read: if signedIn()
          && (resource.data.talentId == request.auth.uid
            || get(/databases/$(database)/documents/auditions/$(auditionId)).data.recruiterId == request.auth.uid);
        allow update: if isRecruiter()
          && get(/databases/$(database)/documents/auditions/$(auditionId)).data.recruiterId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              'status',
              'lastStatusChange',
              'updatedAt',
              'recruiterNotes',
              'rejectionReason'
            ])
          && request.resource.data.status in [
            'APPLIED',
            'VIEWED',
            'SHORTLISTED',
            'REJECTED'
          ];
        allow delete: if isTalent()
          && talentId == request.auth.uid
          && getAfter(/databases/$(database)/documents/auditions/$(auditionId)).data.applicantCount
            == get(/databases/$(database)/documents/auditions/$(auditionId)).data.applicantCount - 1;
      }
    }

    match /{path=**}/applications/{applicationId} {
      allow read: if isTalent()
        && resource.data.talentId == request.auth.uid;
    }
  }
}
