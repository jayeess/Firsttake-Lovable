# Copy this file to .env.e2e.local and add private test-account credentials.
# .env.e2e.local is ignored by Git. Never use personal or production accounts.
E2E_BASE_URL=http://127.0.0.1:3000
E2E_TALENT_EMAIL=e2e.talent@example.com
E2E_TALENT_PASSWORD=replace-with-private-test-password
E2E_RECRUITER_EMAIL=e2e.recruiter@example.com
E2E_RECRUITER_PASSWORD=replace-with-private-test-password
E2E_ADMIN_EMAIL=e2e.admin@example.com
E2E_ADMIN_PASSWORD=replace-with-private-test-password
