rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function owns(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function isActiveRecruiter() {
      return signedIn()
        && firestore.get(
          /databases/(default)/documents/users/$(request.auth.uid)
        ).data.userType == 'RECRUITER'
        && firestore.get(
          /databases/(default)/documents/users/$(request.auth.uid)
        ).data.accountStatus != 'SUSPENDED'
        && firestore.get(
          /databases/(default)/documents/recruiterVerifications/$(request.auth.uid)
        ).data.status == 'approved';
    }

    function isRecruiterAccount(uid) {
      return owns(uid)
        && firestore.get(
          /databases/(default)/documents/users/$(uid)
        ).data.userType == 'RECRUITER'
        && firestore.get(
          /databases/(default)/documents/users/$(uid)
        ).data.accountStatus != 'SUSPENDED';
    }

    function isAllowedImage() {
      return request.resource.contentType in [
        'image/jpeg',
        'image/png',
        'image/webp'
      ];
    }

    function isAllowedRecruiterEvidence() {
      return request.resource.contentType in [
        'image/jpeg',
        'image/png',
        'image/webp',
        'application/pdf'
      ];
    }

    function recruiterVisible() {
      return resource.metadata.visibility in ['recruiters', 'public'];
    }

    match /talent-media/{uid}/profile/{fileName} {
      allow read: if owns(uid)
        || isAdmin()
        || (isActiveRecruiter() && recruiterVisible());
      allow create, update: if owns(uid)
        && request.resource.size <= 5 * 1024 * 1024
        && isAllowedImage()
        && request.resource.metadata.ownerId == uid
        && request.resource.metadata.mediaKind == 'profile'
        && request.resource.metadata.visibility == 'recruiters';
      allow delete: if owns(uid);
    }

    match /talent-media/{uid}/portfolio/{mediaId}/{fileName} {
      allow read: if owns(uid)
        || isAdmin()
        || (isActiveRecruiter() && recruiterVisible());
      allow create, update: if owns(uid)
        && request.resource.size <= 5 * 1024 * 1024
        && isAllowedImage()
        && request.resource.metadata.ownerId == uid
        && request.resource.metadata.mediaKind == 'portfolio'
        && request.resource.metadata.visibility == 'recruiters';
      allow delete: if owns(uid);
    }

    match /recruiter-verification-evidence/{uid}/{evidenceId}/{fileName} {
      allow read: if owns(uid) || isAdmin();
      allow create, update: if isRecruiterAccount(uid)
        && request.resource.size <= 10 * 1024 * 1024
        && isAllowedRecruiterEvidence()
        && request.resource.metadata.ownerId == uid
        && request.resource.metadata.uploadKind == 'recruiter_verification_evidence'
        && request.resource.metadata.visibility == 'private_verification';
      allow delete: if owns(uid);
    }

    match /recruiterProfiles/{uid}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if owns(uid)
        && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
